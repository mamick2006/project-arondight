{
	# quest entities for the Project Arondight mission chain; sprites and icons
	# are the game's own, interaction illustrations are the mod's (registered
	# under graphics.illustrations in data/config/settings.json)
	#
	# the render keys (layers/showInCampaign/showIconOnMap) are LOAD-BEARING:
	# the engine defaults them to hidden/no-layer, so an entry without them is
	# interactable yet INVISIBLE in space and on the map
	"arondight_habitat":{
		"defaultName":"Broceliande Station",
		"defaultRadius":60,
		"nameInText":"station",
		"shortName":"Broceliande Station",
		"aOrAn":"a",
		"isOrAre":"is",
		"interactionImage":"graphics/arondight/illustrations/station_broceliande.jpg",
		"icon":"graphics/icons/station_research_broken.png",
		"iconWidth":20,
		"iconHeight":20,
		"sprite":"graphics/stations/station_side00.png",
		"spriteWidth":50,
		"spriteHeight":50,
		"renderShadow":true,
		"useLightColor":true,
		"showInCampaign":true,
		"showIconOnMap":true,
		"showNameOnMap":false,
		"scaleNameWithZoom":false,
		"scaleIconWithZoom":true,
		"layers":[STATIONS],
		"tags":["has_interaction_dialog","station"],
	},
	"arondight_relay":{
		"defaultName":"Dead Relay",
		"defaultRadius":30,
		"nameInText":"relay",
		"shortName":"relay",
		"aOrAn":"a",
		"isOrAre":"is",
		"interactionImage":"graphics/arondight/illustrations/dead_relay.jpg",
		"icon":"graphics/icons/relay.png",
		"iconWidth":24,
		"iconHeight":24,
		"sprite":"graphics/ships/com_relay.png",
		"spriteWidth":40,
		"spriteHeight":40,
		"renderShadow":true,
		"useLightColor":true,
		"showInCampaign":true,
		"showIconOnMap":true,
		"showNameOnMap":false,
		"scaleNameWithZoom":false,
		"scaleIconWithZoom":true,
		"layers":[STATIONS],
		"tags":["has_interaction_dialog"],
	},
	"arondight_staging":{
		"defaultName":"Deep Anchorage",
		"defaultRadius":40,
		"nameInText":"anchorage",
		"shortName":"anchorage",
		"aOrAn":"a",
		"isOrAre":"is",
		"interactionImage":"graphics/arondight/illustrations/deep_anchorage.jpg",
		"icon":"graphics/icons/intel/discovered_entity.png",
		"iconWidth":24,
		"iconHeight":24,
		"sprite":"graphics/stations/probe.png",
		"spriteWidth":34,
		"spriteHeight":34,
		"renderShadow":true,
		"useLightColor":true,
		"showInCampaign":true,
		"showIconOnMap":true,
		"showNameOnMap":false,
		"scaleNameWithZoom":false,
		"scaleIconWithZoom":true,
		"layers":[STATIONS],
		"tags":["has_interaction_dialog"],
	},
}
